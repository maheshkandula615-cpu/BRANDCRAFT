# BrandCraft AI API Configuration
# Replace 'your-secret-api-key-here' with your actual API key
BRANDCRAFT_API_KEY=your-secret-api-key-here

# Instructions:
# 1. Generate a secure API key (you can use: python -c "import secrets; print(secrets.token_hex(32))")
# 2. Replace the value above with your generated key
# 3. Update the API_KEY constant in script.js with the same key
# 4. Restart the Flask server after making changes